APP_ENV=development
APP_PORT=8000
DATABASE_URL=sqlite:///./question_paraphrase.db

GENERATION_PROVIDER=mock
GENERATION_API_KEY=

EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-small
EMBEDDING_PROVIDER=real_e5
EMBEDDING_DIMENSION=384
VECTOR_INDEX_TYPE=local
VECTOR_TOP_K=10

VALIDATION_SEMANTIC_PASS_MIN=0.86
VALIDATION_SEMANTIC_REVIEW_MIN=0.78
VALIDATION_DUPLICATE_STRONG_MIN=0.88
VALIDATION_DUPLICATE_REVIEW_MIN=0.80
VALIDATION_DUPLICATE_REAL_E5_MIN=0.93
VALIDATION_LEXICAL_TOO_SIMILAR_MAX=0.85
VALIDATION_LEXICAL_TOO_DIFFERENT_MIN=0.15
