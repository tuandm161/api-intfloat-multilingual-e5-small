APP_ENV=development
APP_PORT=8000
DATABASE_URL=sqlite:///./question_paraphrase.db

PARAPHRASE_PROVIDER=local
LOCAL_PARAPHRASE_ENGINE=vietquill
LOCAL_PARAPHRASE_MODEL_REPO_ID=Qwen/Qwen2.5-1.5B-Instruct-GGUF
LOCAL_PARAPHRASE_MODEL_FILENAME=qwen2.5-1.5b-instruct-q4_k_m.gguf
LOCAL_PARAPHRASE_CONTEXT_TOKENS=2048
LOCAL_PARAPHRASE_MAX_TOKENS=1024
LOCAL_PARAPHRASE_TEMPERATURE=0.2
LOCAL_PARAPHRASE_TOP_P=0.9
LOCAL_PARAPHRASE_REPEAT_PENALTY=1.05
LOCAL_PARAPHRASE_THREADS=0
LOCAL_PARAPHRASE_GPU_LAYERS=0
VIETQUILL_MODEL_REPO_ID=ngwgsang/vietquill-vit5-base-tsubaki
VIETQUILL_DEVICE=cpu
VIETQUILL_STYLE=diverse
VIETQUILL_NUM_BEAMS=6
VIETQUILL_MAX_LENGTH=128

GENERATION_PROVIDER=mock
GENERATION_API_KEY=
GENERATION_API_BASE_URL=https://api.deepseek.com
GENERATION_MODEL=deepseek-v4-flash
GENERATION_FALLBACK_MODEL=deepseek-v4-pro
GENERATION_TIMEOUT_SECONDS=60
GENERATION_MAX_RETRIES=1
GENERATION_PROMPT_USD_PER_1M_TOKENS=0
GENERATION_COMPLETION_USD_PER_1M_TOKENS=0

EMBEDDING_MODEL_NAME=intfloat/multilingual-e5-small
EMBEDDING_PROVIDER=real_e5
EMBEDDING_DIMENSION=384
VECTOR_INDEX_TYPE=local
VECTOR_TOP_K=10

DOCUMENT_CHUNK_TARGET_CHARS=7000
DOCUMENT_CHUNK_MAX_CHARS=10000
DOCUMENT_CHUNK_OVERLAP_CHARS=800
DOCUMENT_QUESTIONS_PER_CHUNK=3

VALIDATION_SEMANTIC_PASS_MIN=0.86
VALIDATION_SEMANTIC_REVIEW_MIN=0.78
VALIDATION_DUPLICATE_STRONG_MIN=0.88
VALIDATION_DUPLICATE_REVIEW_MIN=0.80
VALIDATION_DUPLICATE_REAL_E5_MIN=0.93
VALIDATION_LEXICAL_TOO_SIMILAR_MAX=0.85
VALIDATION_LEXICAL_TOO_DIFFERENT_MIN=0.25
